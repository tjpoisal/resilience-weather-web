<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Resilience Weather — NOAA-powered emergency preparedness for every community. Free for everyone.">
  <title>Resilience Weather · NOAA Intelligence for Every Community</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@300;400;500;600;700;900&display=swap" rel="stylesheet">
  <style>
    *{margin:0;padding:0;box-sizing:border-box;}
    :root{
      --bg:#001433;--bg2:#001A4D;--primary:#4A9EFF;
      --green:#10B981;--amber:#F59E0B;--red:#EF4444;
      --text:#F0F6FF;--text2:#94A3B8;--text3:#475569;
      --surface:rgba(255,255,255,0.05);--border:rgba(74,158,255,0.18);
    }
    html{scroll-behavior:smooth;}
    body{
      font-family:'DM Sans',sans-serif;
      background:var(--bg);color:var(--text);
      min-height:100vh;overflow-x:hidden;
    }

    /* ─ SPLASH SCREEN ─ */
    #splash{
      position:fixed;inset:0;z-index:9999;
      background:#000d1f;
      display:flex;flex-direction:column;
      align-items:center;justify-content:center;
      gap:20px;
      transition:opacity 0.6s ease, transform 0.6s ease;
    }
    #splash.hide{opacity:0;pointer-events:none;transform:scale(1.04);}
    .splash-radar{
      position:relative;width:160px;height:160px;
      display:flex;align-items:center;justify-content:center;
    }
    .splash-ring{
      position:absolute;border-radius:50%;
      border:1px solid rgba(74,158,255,0.25);
      animation:radar-pulse 2s ease-out infinite;
    }
    .splash-ring:nth-child(1){width:160px;height:160px;animation-delay:0s;}
    .splash-ring:nth-child(2){width:110px;height:110px;animation-delay:0.4s;}
    .splash-ring:nth-child(3){width:65px;height:65px;animation-delay:0.8s;}
    @keyframes radar-pulse{
      0%{opacity:0.8;border-color:rgba(74,158,255,0.5);}
      100%{opacity:0;transform:scale(1.3);border-color:rgba(74,158,255,0);}
    }
    .splash-shield{
      position:relative;z-index:2;
      width:52px;height:52px;
    }
    .splash-wordmark{
      font-family:'Space Mono',monospace;
      font-size:13px;letter-spacing:3px;
      color:var(--primary);font-weight:700;
      text-transform:uppercase;
    }
    .splash-wordmark span{color:rgba(255,255,255,0.3);}
    .splash-bar{
      width:120px;height:2px;
      background:rgba(74,158,255,0.15);
      border-radius:2px;overflow:hidden;
    }
    .splash-bar-fill{
      height:100%;width:0;
      background:linear-gradient(90deg,#4A9EFF,#10B981);
      border-radius:2px;
      animation:bar-fill 1.6s ease forwards;
    }
    @keyframes bar-fill{to{width:100%;}}

    /* ─ GRID BG ─ */
    body::before{
      content:'';position:fixed;inset:0;
      background-image:
        linear-gradient(rgba(74,158,255,0.03) 1px,transparent 1px),
        linear-gradient(90deg,rgba(74,158,255,0.03) 1px,transparent 1px);
      background-size:44px 44px;pointer-events:none;z-index:0;
    }
    .app{position:relative;z-index:1;}

    /* ─ NAV ─ */
    nav{
      display:flex;align-items:center;justify-content:space-between;
      padding:14px 24px;border-bottom:1px solid var(--border);
      background:rgba(0,20,51,0.9);backdrop-filter:blur(12px);
      position:sticky;top:0;z-index:100;
    }
    .nav-logo{
      font-family:'Space Mono',monospace;font-size:13px;font-weight:700;
      color:var(--primary);letter-spacing:2px;text-decoration:none;
    }
    .nav-logo span{color:rgba(255,255,255,0.35);}
    .nav-right{display:flex;align-items:center;gap:10px;}
    .btn{
      display:inline-flex;align-items:center;gap:6px;
      padding:8px 16px;border-radius:8px;
      font-size:12px;font-weight:700;cursor:pointer;
      text-decoration:none;border:none;
      font-family:'DM Sans',sans-serif;transition:all 0.15s;
    }
    .btn-primary{background:var(--primary);color:#001433;}
    .btn-primary:hover{background:#6FB3FF;transform:translateY(-1px);}
    .btn-outline{background:transparent;border:1px solid var(--border);color:var(--text);}
    .btn-outline:hover{border-color:var(--primary);}
    .btn-sm{padding:6px 12px;font-size:11px;}

    /* ─ HERO ─ */
    .hero{
      padding:90px 24px 100px;text-align:center;
      max-width:900px;margin:0 auto;
    }
    .hero-badge{
      display:inline-flex;align-items:center;gap:8px;
      background:rgba(16,185,129,0.1);
      border:1px solid rgba(16,185,129,0.25);
      border-radius:999px;padding:7px 18px;
      font-size:10px;font-weight:800;color:var(--green);
      letter-spacing:1.5px;text-transform:uppercase;margin-bottom:28px;
    }
    .hero h1{
      font-size:clamp(38px,6vw,64px);font-weight:900;
      line-height:1.1;margin-bottom:22px;letter-spacing:-1px;
    }
    .hero h1 em{color:var(--primary);font-style:normal;}
    .hero p{
      font-size:18px;color:var(--text2);line-height:1.7;
      max-width:640px;margin:0 auto 44px;
    }
    .hero-cta{
      display:flex;gap:14px;justify-content:center;
      flex-wrap:wrap;margin-bottom:70px;
    }
    .cta-btn{
      display:inline-flex;align-items:center;gap:9px;
      padding:16px 30px;border-radius:12px;
      font-size:15px;font-weight:800;cursor:pointer;
      text-decoration:none;border:none;
      font-family:'DM Sans',sans-serif;transition:all 0.2s;
    }
    .cta-primary{background:var(--primary);color:#001433;}
    .cta-primary:hover{background:#6FB3FF;transform:translateY(-2px);box-shadow:0 8px 24px rgba(74,158,255,0.3);}
    .cta-secondary{background:transparent;border:2px solid var(--primary);color:var(--primary);}
    .cta-secondary:hover{background:rgba(74,158,255,0.1);transform:translateY(-2px);}

    /* ─ WEATHER SVG ICONS ROW ─ */
    .icon-row{
      display:flex;justify-content:center;gap:28px;
      flex-wrap:wrap;padding:40px 24px;
      border-top:1px solid var(--border);
      border-bottom:1px solid var(--border);
      margin-bottom:80px;
    }
    .icon-item{
      display:flex;flex-direction:column;align-items:center;
      gap:10px;
    }
    .icon-item svg{
      width:48px;height:48px;
      color:var(--primary);
      opacity:0.85;
      transition:opacity 0.2s,transform 0.2s;
    }
    .icon-item:hover svg{opacity:1;transform:translateY(-3px);}
    .icon-label{font-size:10px;font-weight:700;letter-spacing:1.2px;color:var(--text2);text-transform:uppercase;}

    /* ─ SECTIONS ─ */
    .section{padding:80px 24px;max-width:1200px;margin:0 auto;}
    .section-title{
      font-size:clamp(26px,4vw,44px);font-weight:900;
      text-align:center;margin-bottom:14px;letter-spacing:-0.5px;
    }
    .section-title em{color:var(--primary);font-style:normal;}
    .section-sub{
      text-align:center;color:var(--text2);
      font-size:16px;max-width:580px;margin:0 auto 48px;line-height:1.6;
    }

    /* ─ FEATURE CARDS ─ */
    .features-grid{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
      gap:20px;margin-bottom:60px;
    }
    .feature-card{
      background:var(--surface);border:1px solid var(--border);
      border-radius:16px;padding:28px 24px;
      transition:all 0.25s;position:relative;overflow:hidden;
    }
    .feature-card::after{
      content:'';position:absolute;top:-40px;right:-40px;
      width:120px;height:120px;border-radius:50%;
      background:radial-gradient(circle,rgba(74,158,255,0.08) 0%,transparent 70%);
      pointer-events:none;
    }
    .feature-card:hover{border-color:rgba(74,158,255,0.5);transform:translateY(-3px);background:rgba(74,158,255,0.06);}
    .feature-icon-wrap{
      width:44px;height:44px;border-radius:10px;
      background:rgba(74,158,255,0.1);border:1px solid rgba(74,158,255,0.2);
      display:flex;align-items:center;justify-content:center;
      margin-bottom:16px;
    }
    .feature-icon-wrap svg{width:22px;height:22px;color:var(--primary);}
    .feature-card h3{font-size:17px;font-weight:800;margin-bottom:8px;}
    .feature-card p{font-size:14px;color:var(--text2);line-height:1.6;}

    /* ─ PROFILES ─ */
    .profiles-grid{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(170px,1fr));
      gap:12px;
    }
    .profile-badge{
      background:rgba(74,158,255,0.07);
      border:1px solid rgba(74,158,255,0.18);
      border-radius:10px;padding:14px 12px;
      text-align:center;font-size:13px;font-weight:700;
      transition:all 0.2s;cursor:default;
    }
    .profile-badge:hover{border-color:var(--primary);background:rgba(74,158,255,0.12);transform:translateY(-2px);}

    /* ─ DOWNLOAD ─ */
    .download-section{
      background:linear-gradient(135deg,rgba(74,158,255,0.08) 0%,rgba(16,185,129,0.06) 100%);
      border:1px solid rgba(74,158,255,0.2);
      border-radius:24px;padding:56px 40px;text-align:center;margin-bottom:80px;
    }
    .download-section h2{font-size:36px;font-weight:900;margin-bottom:16px;}
    .download-section p{font-size:16px;color:var(--text2);margin-bottom:36px;}
    .download-buttons{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;}
    .dl-btn{
      display:inline-flex;align-items:center;justify-content:center;gap:9px;
      padding:14px 28px;border-radius:12px;border:none;
      font-size:14px;font-weight:800;cursor:pointer;
      font-family:'DM Sans',sans-serif;text-decoration:none;
      transition:all 0.2s;letter-spacing:0.3px;
    }
    .dl-ios{background:var(--primary);color:#001433;}
    .dl-ios:hover{background:#6FB3FF;transform:translateY(-2px);}
    .dl-android{background:var(--green);color:#001A0A;}
    .dl-android:hover{background:#34D399;transform:translateY(-2px);}
    .dl-web{background:transparent;border:2px solid var(--primary);color:var(--primary);}
    .dl-web:hover{background:rgba(74,158,255,0.1);transform:translateY(-2px);}

    /* ─ FOOTER ─ */
    footer{
      padding:36px 24px;border-top:1px solid var(--border);
      text-align:center;color:var(--text2);font-size:12px;
    }
    footer a{color:var(--primary);text-decoration:none;}
    footer a:hover{text-decoration:underline;}

    @media(max-width:768px){
      .hero{padding:60px 24px 80px;}
      .section{padding:60px 24px;}
      .download-section{padding:40px 24px;}
      .download-buttons{flex-direction:column;}
      .dl-btn{width:100%;}
      .icon-row{gap:20px;}
    }
  </style>
</head>
<body>

<!-- ─ SPLASH SCREEN ─ -->
<div id="splash">
  <div class="splash-radar">
    <div class="splash-ring"></div>
    <div class="splash-ring"></div>
    <div class="splash-ring"></div>
    <svg class="splash-shield" viewBox="0 0 52 60" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M26 2L4 12V28C4 41.3 13.6 53.7 26 58C38.4 53.7 48 41.3 48 28V12L26 2Z" fill="rgba(74,158,255,0.15)" stroke="#4A9EFF" stroke-width="2"/>
      <path d="M18 30L23 35L34 24" stroke="#4A9EFF" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>
  <div class="splash-wordmark">RESILIENCE <span>WEATHER</span></div>
  <div class="splash-bar"><div class="splash-bar-fill"></div></div>
</div>

<div class="app">
  <!-- NAV -->
  <nav>
    <a href="/" class="nav-logo">RESILIENCE <span>WEATHER</span></a>
    <div class="nav-right">
      <a href="/dashboard" class="btn btn-outline btn-sm">Web App</a>
      <a href="/login" class="btn btn-primary btn-sm">Sign In</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-badge">&#9679; POWERED BY LIVE NOAA DATA</div>
    <h1>Weather Intelligence <em>Built for Everyone</em></h1>
    <p>Free, accessible emergency weather for every community. From farmers to first responders, families to fishing crews — NOAA data adapted to how you actually live and work.</p>
    <div class="hero-cta">
      <a href="/dashboard" class="cta-btn cta-primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        Open Live Weather
      </a>
      <a href="#download" class="cta-btn cta-secondary">Download the App</a>
    </div>
  </section>

  <!-- SVG WEATHER ICON ROW — Scandinavian minimal style -->
  <div class="icon-row">
    <!-- Sun -->
    <div class="icon-item">
      <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
        <circle cx="24" cy="24" r="8"/>
        <line x1="24" y1="4" x2="24" y2="10"/>
        <line x1="24" y1="38" x2="24" y2="44"/>
        <line x1="4" y1="24" x2="10" y2="24"/>
        <line x1="38" y1="24" x2="44" y2="24"/>
        <line x1="9.5" y1="9.5" x2="13.7" y2="13.7"/>
        <line x1="34.3" y1="34.3" x2="38.5" y2="38.5"/>
        <line x1="38.5" y1="9.5" x2="34.3" y2="13.7"/>
        <line x1="13.7" y1="34.3" x2="9.5" y2="38.5"/>
      </svg>
      <span class="icon-label">Clear</span>
    </div>
    <!-- Partly cloudy -->
    <div class="icon-item">
      <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="18" cy="20" r="6"/>
        <line x1="18" y1="8" x2="18" y2="11"/>
        <line x1="8" y1="20" x2="11" y2="20"/>
        <line x1="10.9" y1="12.9" x2="13" y2="15"/>
        <path d="M26 26H14a7 7 0 010-14 7 7 0 0113.3 3A5 5 0 1126 26z"/>
      </svg>
      <span class="icon-label">Partly</span>
    </div>
    <!-- Cloud -->
    <div class="icon-item">
      <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M36 34H12a10 10 0 010-20 10 10 0 0119.3 4A7 7 0 1136 34z"/>
      </svg>
      <span class="icon-label">Cloudy</span>
    </div>
    <!-- Rain -->
    <div class="icon-item">
      <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M34 28H14a9 9 0 010-18 9 9 0 0117.4 3.6A6 6 0 1134 28z"/>
        <line x1="16" y1="34" x2="14" y2="40"/>
        <line x1="24" y1="34" x2="22" y2="40"/>
        <line x1="32" y1="34" x2="30" y2="40"/>
      </svg>
      <span class="icon-label">Rain</span>
    </div>
    <!-- Snow -->
    <div class="icon-item">
      <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M33 26H15a8 8 0 010-16 8 8 0 0115.6 3.2A5 5 0 1133 26z"/>
        <line x1="16" y1="33" x2="16" y2="41"/>
        <line x1="12" y1="37" x2="20" y2="37"/>
        <line x1="24" y1="33" x2="24" y2="41"/>
        <line x1="20" y1="37" x2="28" y2="37"/>
        <line x1="32" y1="33" x2="32" y2="41"/>
        <line x1="28" y1="37" x2="36" y2="37"/>
      </svg>
      <span class="icon-label">Snow</span>
    </div>
    <!-- Thunder -->
    <div class="icon-item">
      <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M34 26H14a9 9 0 010-18 9 9 0 0117.4 3.6A6 6 0 1134 26z"/>
        <polyline points="27,26 22,36 26,36 21,44"/>
      </svg>
      <span class="icon-label">Storm</span>
    </div>
    <!-- Wind -->
    <div class="icon-item">
      <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
        <path d="M8 18h22a6 6 0 100-6"/>
        <path d="M8 24h28a6 6 0 110 6H28"/>
        <path d="M8 30h16"/>
      </svg>
      <span class="icon-label">Wind</span>
    </div>
    <!-- Fog -->
    <div class="icon-item">
      <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
        <line x1="8" y1="20" x2="40" y2="20"/>
        <line x1="10" y1="26" x2="38" y2="26"/>
        <line x1="8" y1="32" x2="36" y2="32"/>
        <line x1="12" y1="38" x2="34" y2="38"/>
      </svg>
      <span class="icon-label">Fog</span>
    </div>
  </div>

  <!-- FEATURES -->
  <section class="section" id="features">
    <h2 class="section-title">Why <em>Resilience</em>?</h2>
    <p class="section-sub">Free NOAA intelligence designed from the ground up for communities that need it most — not just people who can afford premium weather apps.</p>
    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon-wrap">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15 15 0 010 20"/></svg>
        </div>
        <h3>Live NOAA Integration</h3>
        <p>Direct feed from National Weather Service — the same data professional forecasters use, available to everyone for free.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon-wrap">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="16" y1="2" x2="16" y2="6"/></svg>
        </div>
        <h3>7-Day Forecast</h3>
        <p>Full week ahead with precipitation probability, wind, humidity, and a confidence score so you know how much to trust the forecast.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon-wrap">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        </div>
        <h3>Emergency Alerts</h3>
        <p>Severe weather, flood watches, heat advisories — delivered instantly, no subscription required.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon-wrap">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
        </div>
        <h3>15 Operational Profiles</h3>
        <p>Farmer, mariner, first responder, or family — the data you see and how it's presented adapts to your life.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon-wrap">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M1 6l5 5 5-5 5 5 5-5v12a2 2 0 01-2 2H3a2 2 0 01-2-2z"/></svg>
        </div>
        <h3>Offline-First Design</h3>
        <p>Tiered connectivity — works at full capacity on 4G, degrades gracefully to mesh networking when infrastructure fails.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon-wrap">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
        </div>
        <h3>Zero-Tracking Privacy</h3>
        <p>No ads on Pro. No data sold. Your location never leaves your device unless you explicitly share an observation.</p>
      </div>
    </div>
  </section>

  <!-- PROFILES -->
  <section class="section">
    <h2 class="section-title">Built for <em>Your Community</em></h2>
    <p class="section-sub">15 specialized profiles — free for every person, every role, every need</p>
    <div class="profiles-grid">
      <div class="profile-badge">General Public</div>
      <div class="profile-badge">Universal / Zero-Literacy</div>
      <div class="profile-badge">Marine / Fisher</div>
      <div class="profile-badge">Agricultural</div>
      <div class="profile-badge">Construction / Safety</div>
      <div class="profile-badge">Tribal / Arctic</div>
      <div class="profile-badge">Aviation / Drone</div>
      <div class="profile-badge">Neurodivergent</div>
      <div class="profile-badge">City / Urban Health</div>
      <div class="profile-badge">Post-Disaster Recovery</div>
      <div class="profile-badge">Commuter / Logistics</div>
      <div class="profile-badge">Citizen Science</div>
      <div class="profile-badge">Event Organizer</div>
      <div class="profile-badge">Family / Multi-Location</div>
      <div class="profile-badge">Renewable Energy / Grid</div>
    </div>
  </section>

  <!-- DOWNLOAD -->
