<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Download · Resilience Weather</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@300;400;500;600;700;900&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;}
:root{
  --bg:#001433;--bg2:#001A4D;--primary:#4A9EFF;
  --green:#10B981;--amber:#F59E0B;--red:#EF4444;
  --text:#F0F6FF;--text2:#94A3B8;--text3:#475569;
  --surface:rgba(255,255,255,0.05);--border:rgba(74,158,255,0.18);
}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden;}
body::before{content:'';position:fixed;inset:0;
  background-image:linear-gradient(rgba(74,158,255,0.03) 1px,transparent 1px),
    linear-gradient(90deg,rgba(74,158,255,0.03) 1px,transparent 1px);
  background-size:44px 44px;pointer-events:none;z-index:0;}
.app{position:relative;z-index:1;min-height:100vh;display:flex;flex-direction:column;}

/* NAV */
nav{display:flex;align-items:center;justify-content:space-between;padding:14px 24px;
  border-bottom:1px solid var(--border);background:rgba(0,20,51,0.9);
  backdrop-filter:blur(12px);position:sticky;top:0;z-index:100;}
.nav-logo{font-family:'Space Mono',monospace;font-size:13px;font-weight:700;
  color:var(--primary);letter-spacing:2px;text-decoration:none;}
.nav-logo span{color:rgba(255,255,255,0.35);}
.nav-right{display:flex;align-items:center;gap:10px;}
.btn{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border-radius:8px;
  font-size:12px;font-weight:700;cursor:pointer;text-decoration:none;border:none;
  font-family:'DM Sans',sans-serif;transition:all 0.15s;}
.btn-primary{background:var(--primary);color:#001433;}
.btn-primary:hover{background:#6FB3FF;transform:translateY(-1px);}
.btn-outline{background:transparent;border:1px solid var(--border);color:var(--text);}
.btn-outline:hover{border-color:var(--primary);}
.btn-sm{padding:6px 12px;font-size:11px;}

/* HERO */
.hero{padding:80px 24px 60px;text-align:center;max-width:860px;margin:0 auto;}
.hero-badge{display:inline-flex;align-items:center;gap:8px;
  background:rgba(74,158,255,0.1);border:1px solid rgba(74,158,255,0.25);
  border-radius:999px;padding:6px 16px;font-size:11px;font-weight:700;
  color:var(--primary);letter-spacing:1px;margin-bottom:24px;}
.hero h1{font-size:clamp(32px,5vw,54px);font-weight:900;line-height:1.1;margin-bottom:16px;}
.hero h1 span{color:var(--primary);}
.hero p{font-size:16px;color:var(--text2);line-height:1.7;max-width:560px;margin:0 auto 40px;}

/* APP PREVIEW */
.app-preview{display:flex;align-items:center;justify-content:center;gap:20px;
  margin-bottom:20px;flex-wrap:wrap;}
.app-icon-wrap{position:relative;}
.app-icon{width:96px;height:96px;border-radius:22px;
  background:linear-gradient(135deg,rgba(74,158,255,0.2),rgba(74,158,255,0.05));
  border:1px solid rgba(74,158,255,0.3);
  display:flex;align-items:center;justify-content:center;font-size:44px;
  box-shadow:0 0 40px rgba(74,158,255,0.15);}
.app-info{text-align:left;}
.app-info h2{font-size:22px;font-weight:900;margin-bottom:4px;}
.app-info p{font-size:13px;color:var(--text2);}
.stars{color:#F59E0B;font-size:14px;margin-top:4px;}

/* DOWNLOAD CARDS */
.download-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;
  max-width:760px;margin:0 auto 60px;padding:0 24px;}
@media(max-width:600px){.download-grid{grid-template-columns:1fr;}}

.dl-card{
  border-radius:20px;padding:32px 28px;
  background:var(--surface);border:1px solid var(--border);
  position:relative;overflow:hidden;transition:border-color 0.2s,transform 0.2s;
}
.dl-card:hover{border-color:var(--primary);transform:translateY(-2px);}
.dl-card::before{content:'';position:absolute;top:-60px;right:-60px;
  width:200px;height:200px;border-radius:50%;
  background:radial-gradient(circle,var(--card-glow,rgba(74,158,255,0.08)) 0%,transparent 70%);
  pointer-events:none;}
.dl-card.android{--card-glow:rgba(16,185,129,0.1);}
.dl-card.ios{--card-glow:rgba(74,158,255,0.1);}

.platform-icon{font-size:40px;margin-bottom:16px;display:block;}
.platform-name{font-size:11px;font-weight:800;letter-spacing:2px;
  text-transform:uppercase;color:var(--text2);margin-bottom:6px;}
.platform-title{font-size:22px;font-weight:900;margin-bottom:8px;}
.platform-desc{font-size:13px;color:var(--text2);line-height:1.6;margin-bottom:20px;}

.dl-btn{
  display:flex;align-items:center;justify-content:center;gap:10px;
  width:100%;padding:14px 20px;border-radius:12px;border:none;
  font-size:14px;font-weight:900;cursor:pointer;
  font-family:'DM Sans',sans-serif;transition:all 0.15s;
  text-decoration:none;
}
.dl-btn-android{background:var(--green);color:#001A0A;}
.dl-btn-android:hover{background:#34D399;transform:translateY(-1px);}
.dl-btn-ios{background:var(--primary);color:#001433;}
.dl-btn-ios:hover{background:#6FB3FF;transform:translateY(-1px);}
.dl-btn-disabled{background:rgba(255,255,255,0.06);color:var(--text3);
  border:1px solid rgba(255,255,255,0.1);cursor:not-allowed;}

.version-tag{font-size:10px;color:var(--text3);margin-top:10px;text-align:center;}

.install-steps{margin-top:16px;padding-top:16px;border-top:1px solid rgba(255,255,255,0.06);}
.install-steps summary{font-size:11px;font-weight:700;color:var(--text3);
  cursor:pointer;user-select:none;letter-spacing:0.5px;}
.install-steps summary:hover{color:var(--text2);}
.steps-list{margin-top:10px;display:flex;flex-direction:column;gap:7px;}
.step{display:flex;gap:10px;align-items:flex-start;font-size:12px;color:var(--text2);}
.step-num{min-width:20px;height:20px;border-radius:50%;
  background:rgba(74,158,255,0.15);border:1px solid rgba(74,158,255,0.25);
  display:flex;align-items:center;justify-content:center;
  font-size:10px;font-weight:800;color:var(--primary);}

/* FEATURES */
.features{max-width:860px;margin:0 auto;padding:0 24px 80px;}
.sec-title{font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;
  color:var(--text2);margin-bottom:20px;display:flex;align-items:center;gap:8px;}
.sec-title::after{content:'';flex:1;height:1px;background:var(--border);}
.features-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;}
@media(max-width:600px){.features-grid{grid-template-columns:1fr 1fr;}}
.feat{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:16px;}
.feat-icon{font-size:24px;margin-bottom:8px;}
.feat-name{font-size:13px;font-weight:800;margin-bottom:4px;}
.feat-desc{font-size:11px;color:var(--text2);line-height:1.5;}
.feat-pro{display:inline-block;font-size:9px;font-weight:800;letter-spacing:1px;
  padding:2px 7px;border-radius:999px;margin-left:5px;
  background:rgba(74,158,255,0.15);border:1px solid rgba(74,158,255,0.3);color:var(--primary);}

/* QR */
.qr-section{max-width:860px;margin:0 auto;padding:0 24px 80px;text-align:center;}
.qr-box{display:inline-block;background:white;border-radius:16px;padding:16px;margin:20px auto;}
.qr-box img{width:140px;height:140px;display:block;}
.qr-placeholder{width:140px;height:140px;display:flex;align-items:center;justify-content:center;
  background:#f0f0f0;border-radius:8px;font-size:11px;color:#666;text-align:center;padding:8px;}

/* NOTICE */
.notice{max-width:760px;margin:0 auto 40px;padding:0 24px;}
.notice-box{background:rgba(245,158,11,0.08);border:1px solid rgba(245,158,11,0.25);
  border-radius:12px;padding:16px 20px;font-size:12px;color:var(--text2);line-height:1.6;}
.notice-box strong{color:var(--amber);}

/* FOOTER */
footer{border-top:1px solid var(--border);padding:24px;text-align:center;
  font-size:11px;color:var(--text3);}
footer a{color:var(--primary);text-decoration:none;}

/* SPINNER */
.spin{display:inline-block;width:14px;height:14px;
  border:2px solid rgba(0,20,51,0.3);border-top-color:#001433;
  border-radius:50%;animation:spin 0.7s linear infinite;vertical-align:middle;}
@keyframes spin{to{transform:rotate(360deg)}}
</style>
</head>
<body>
<div class="app">

<nav>
  <a href="/" class="nav-logo">RESILIENCE <span>WEATHER</span></a>
  <div class="nav-right">
    <a href="/" class="btn btn-outline btn-sm">← Dashboard</a>
    <% if (!isPro) { %>
    <a href="/upgrade" class="btn btn-primary btn-sm">⚡ Go Pro</a>
    <% } %>
  </div>
</nav>

<main>
<!-- HERO -->
<div class="hero">
  <div class="hero-badge">📱 DIRECT DOWNLOAD · NO APP STORE REQUIRED</div>
  <h1>Get <span>Resilience Weather</span><br>on your device</h1>
  <p>Real-time NOAA alerts, AI hazard intelligence, and offline emergency tools. Install directly — no Apple ID or Google account required.</p>

  <div class="app-preview">
    <div class="app-icon-wrap">
      <div class="app-icon">🛡️</div>
    </div>
    <div class="app-info">
      <h2>Resilience Weather</h2>
      <p>by Get Stack MAX LLC</p>
      <p style="font-size:12px;color:var(--text2);margin-top:2px;">v1.0.0 · Built on NOAA data</p>
      <div class="stars">★★★★★ <span style="font-size:11px;color:var(--text2);">Stay ahead of every hazard</span></div>
    </div>
  </div>
</div>

<!-- DOWNLOAD CARDS -->
<div class="download-grid">

  <!-- ANDROID -->
  <div class="dl-card android">
    <span class="platform-icon">🤖</span>
    <div class="platform-name">Android</div>
    <div class="platform-title">Direct APK</div>
    <p class="platform-desc">Install directly on any Android device. No Google Play account needed. Works on phones, tablets, and Chromebooks.</p>

    <% if (typeof androidApkUrl !== 'undefined' && androidApkUrl) { %>
      <a href="<%= androidApkUrl %>" class="dl-btn dl-btn-android" id="android-dl-btn">
        ⬇ Download APK
      </a>
      <div class="version-tag" id="android-version">v<%= androidVersion || '1.0.0' %> · <%= androidSize || '~45 MB' %></div>
    <% } else { %>
      <button class="dl-btn dl-btn-disabled" disabled>⏳ Build Coming Soon</button>
      <div class="version-tag">We're finishing the Android build</div>
    <% } %>

    <details class="install-steps">
      <summary>How to install ▾</summary>
      <div class="steps-list">
        <div class="step"><div class="step-num">1</div><span>Tap the download button above to get the APK file</span></div>
        <div class="step"><div class="step-num">2</div><span>Open your Downloads folder and tap the .apk file</span></div>
        <div class="step"><div class="step-num">3</div><span>If prompted, go to Settings → Security → enable "Install unknown apps" for your browser</span></div>
        <div class="step"><div class="step-num">4</div><span>Tap Install and open Resilience Weather</span></div>
      </div>
    </details>
  </div>

  <!-- IOS -->
  <div class="dl-card ios">
    <span class="platform-icon"></span>
    <div class="platform-name">iPhone &amp; iPad</div>
    <div class="platform-title">Direct Install</div>
    <p class="platform-desc">Install via OTA (Over-The-Air) without the App Store. Works on iOS 15+. You may need to trust the certificate once after install.</p>

    <% if (typeof iosManifestUrl !== 'undefined' && iosManifestUrl) { %>
      <a href="itms-services://?action=download-manifest&url=<%= encodeURIComponent(iosManifestUrl) %>" 
         class="dl-btn dl-btn-ios" id="ios-dl-btn">
         Install on iPhone / iPad
      </a>
      <div class="version-tag" id="ios-version">v<%= iosVersion || '1.0.0' %> · iOS 15+ required</div>
    <% } else { %>
      <button class="dl-btn dl-btn-disabled" disabled>⏳ Build Coming Soon</button>
      <div class="version-tag">We're finishing the iOS build</div>
    <% } %>

    <details class="install-steps">
      <summary>How to install ▾</summary>
      <div class="steps-list">
        <div class="step"><div class="step-num">1</div><span>Tap the install button above <strong>in Safari</strong> (other browsers won't work for iOS install)</span></div>
        <div class="step"><div class="step-num">2</div><span>Tap "Install" when the system prompt appears</span></div>
        <div class="step"><div class="step-num">3</div><span>Go to Settings → General → VPN &amp; Device Management</span></div>
        <div class="step"><div class="step-num">4</div><span>Tap the Get Stack MAX LLC profile → Trust it → Open Resilience Weather</span></div>
      </div>
    </details>
  </div>

</div>

<!-- SIDELOAD NOTICE -->
<div class="notice">
  <div class="notice-box">
    <strong>⚠️ Direct install notice:</strong> These builds are signed by Get Stack MAX LLC and distributed outside the official app stores. Android users: you'll need to allow "unknown sources" once. iOS users: you'll need to trust the developer certificate in Settings after install. This is normal for enterprise and beta distribution.
  </div>
</div>

<!-- FEATURES -->
<div class="features">
  <div class="sec-title">What's in the app</div>
  <div class="features-grid">
    <div class="feat">
      <div class="feat-icon">🛡️</div>
      <div class="feat-name">Signal System</div>
      <div class="feat-desc">Color-coded hazard levels from NOAA alerts in real time</div>
    </div>
    <div class="feat">
      <div class="feat-icon">📡</div>
      <div class="feat-name">Live Radar<span class="feat-pro">PRO</span></div>
      <div class="feat-desc">Full NOAA radar station overlay with storm tracking</div>
    </div>
    <div class="feat">
      <div class="feat-icon">🌡️</div>
      <div class="feat-name">WBGT Heat Stress<span class="feat-pro">PRO</span></div>
      <div class="feat-desc">OSHA heat stress index with real-time advisory thresholds</div>
    </div>
    <div class="feat">
      <div class="feat-icon">📍</div>
      <div class="feat-name">GPS + Offline</div>
      <div class="feat-desc">Auto-detect location. Cached data works without a signal</div>
    </div>
    <div class="feat">
      <div class="feat-icon">⌚</div>
      <div class="feat-name">Apple Watch<span class="feat-pro">PRO</span></div>
      <div class="feat-desc">Glanceable hazard level and temperature on your wrist</div>
    </div>
    <div class="feat">
      <div class="feat-icon">🔔</div>
      <div class="feat-name">Push Alerts</div>
      <div class="feat-desc">Instant NOAA severe weather notifications before they hit</div>
    </div>
    <div class="feat">
      <div class="feat-icon">🌊</div>
      <div class="feat-name">Flood Risk Index<span class="feat-pro">PRO</span></div>
      <div class="feat-desc">Calculated flood probability from NOAA gauge data</div>
    </div>
    <div class="feat">
      <div class="feat-icon">🧪</div>
      <div class="feat-name">Citizen Science</div>
      <div class="feat-desc">Submit observations directly to NOAA CoCoRaHS network</div>
    </div>
    <div class="feat">
      <div class="feat-icon">📦</div>
      <div class="feat-name">Home Inventory<span class="feat-pro">PRO</span></div>
      <div class="feat-desc">Document your assets for insurance claims after disasters</div>
    </div>
  </div>
</div>

<!-- QR CODES -->
<div class="qr-section">
  <div class="sec-title" style="max-width:860px;margin:0 auto 0;">Scan to download</div>
  <p style="color:var(--text2);font-size:13px;margin:12px 0 24px;">Point your camera at the QR code to go directly to this download page</p>
  <div style="display:flex;gap:40px;justify-content:center;flex-wrap:wrap;">
    <div>
      <div class="qr-box">
        <div class="qr-placeholder" id="qr-android">
          <span>QR for<br>Android<br>Download</span>
        </div>
      </div>
      <p style="font-size:11px;color:var(--text3);margin-top:6px;">Android APK</p>
    </div>
    <div>
      <div class="qr-box">
        <div class="qr-placeholder" id="qr-ios">
          <span>QR for<br>iOS<br>Install</span>
        </div>
      </div>
      <p style="font-size:11px;color:var(--text3);margin-top:6px;">iPhone / iPad</p>
    </div>
  </div>
</div>

</main>

<footer>
  <p>Resilience Weather · Built by <a href="https://getstackmax.com" target="_blank">Get Stack MAX LLC</a> · Powered by NOAA</p>
  <p style="margin-top:6px;"><a href="/">Dashboard</a> · <a href="/upgrade">Go Pro</a> · <a href="/login">Sign In</a></p>
</footer>

</div>

<script>
// Generate QR codes using a free API
function loadQR() {
  const base = window.location.origin;
  const androidUrl = base + '/download#android';
  const iosUrl = base + '/download#ios';

  ['qr-android', 'qr-ios'].forEach((id, i) => {
    const url = i === 0 ? androidUrl : iosUrl;
    const qrUrl = `https://api.qrserver.com/v1/create-qr-code/?size=140x140&data=${encodeURIComponent(url)}&color=001433&bgcolor=FFFFFF&margin=10`;
    document.getElementById(id).innerHTML = `<img src="${qrUrl}" width="140" height="140" alt="QR Code" style="border-radius:4px;" />`;
  });
}

loadQR();

// Smooth scroll to platform section from URL hash
if (window.location.hash === '#android') {
  document.querySelector('.dl-card.android')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
}
if (window.location.hash === '#ios') {
  document.querySelector('.dl-card.ios')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
}

// Detect mobile platform and highlight the right card
const ua = navigator.userAgent;
if (/android/i.test(ua)) {
  document.querySelector('.dl-card.android').style.borderColor = 'var(--green)';
  document.querySelector('.dl-card.android').style.boxShadow = '0 0 30px rgba(16,185,129,0.1)';
} else if (/iphone|ipad/i.test(ua)) {
  document.querySelector('.dl-card.ios').style.borderColor = 'var(--primary)';
  document.querySelector('.dl-card.ios').style.boxShadow = '0 0 30px rgba(74,158,255,0.15)';
}
</script>
</body>
</html>
