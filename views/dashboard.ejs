<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Resilience Weather</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@300;400;500;600;700;900&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#001433;--bg2:#001A4D;--primary:#4A9EFF;
  --green:#10B981;--amber:#F59E0B;--red:#EF4444;--purple:#A21CAF;
  --text:#F0F6FF;--text2:#94A3B8;--text3:#475569;
  --surface:rgba(255,255,255,0.06);--border:rgba(74,158,255,0.18);
}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden;}
body::before{content:'';position:fixed;inset:0;
  background-image:linear-gradient(rgba(74,158,255,0.035) 1px,transparent 1px),linear-gradient(90deg,rgba(74,158,255,0.035) 1px,transparent 1px);
  background-size:44px 44px;pointer-events:none;z-index:0;}
.app{position:relative;z-index:1;min-height:100vh;display:flex;flex-direction:column;}

/* ─ NAV ─ */
nav{display:flex;align-items:center;justify-content:space-between;padding:14px 24px;
  border-bottom:1px solid var(--border);background:rgba(0,20,51,0.85);
  backdrop-filter:blur(12px);position:sticky;top:0;z-index:100;}
.nav-logo{font-family:'Space Mono',monospace;font-size:13px;font-weight:700;
  color:var(--primary);letter-spacing:2px;text-decoration:none;}
.nav-logo span{color:rgba(255,255,255,0.35);}
.nav-right{display:flex;align-items:center;gap:10px;}
.plan-badge{font-size:9px;font-weight:800;letter-spacing:1.5px;padding:3px 10px;border-radius:999px;}
.plan-free{background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);color:var(--text2);}
.plan-pro{background:rgba(74,158,255,0.18);border:1px solid rgba(74,158,255,0.4);color:var(--primary);}
.btn{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border-radius:8px;
  font-size:12px;font-weight:700;cursor:pointer;text-decoration:none;border:none;
  font-family:'DM Sans',sans-serif;transition:all 0.15s;}
.btn-primary{background:var(--primary);color:#001433;}
.btn-primary:hover{background:#6FB3FF;}
.btn-outline{background:transparent;border:1px solid var(--border);color:var(--text);}
.btn-outline:hover{border-color:var(--primary);}
.btn-sm{padding:6px 12px;font-size:11px;}
main{flex:1;padding:28px 24px;max-width:1100px;width:100%;margin:0 auto;}

/* ─ LOCATION BAR ─ */
.loc-bar{display:flex;align-items:center;gap:10px;margin-bottom:24px;flex-wrap:wrap;}
.loc-input{flex:1;min-width:220px;background:var(--surface);border:1px solid var(--border);
  border-radius:10px;padding:10px 14px;color:var(--text);font-family:'DM Sans',sans-serif;
  font-size:13px;outline:none;}
.loc-input:focus{border-color:var(--primary);}
.live-dot{width:8px;height:8px;border-radius:50%;background:var(--green);
  box-shadow:0 0 6px var(--green);animation:blink 1.4s ease infinite;}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0.2}}

/* ─ SIGNAL CARD ─ */
.signal-card{
  border-radius:20px;padding:28px 24px;margin-bottom:20px;
  border:1px solid;position:relative;overflow:hidden;
  transition:background 0.5s,border-color 0.5s;
  background:var(--sig-bg,var(--bg2));
  border-color:var(--sig-border,var(--border));
}
.signal-card::before{
  content:'';position:absolute;inset:0;
  background:radial-gradient(circle at 30% 50%, var(--sig-glow,rgba(74,158,255,0.08)) 0%,transparent 70%);
  pointer-events:none;
}
.signal-label{font-size:9px;font-weight:800;letter-spacing:2px;text-transform:uppercase;
  color:var(--sig-color,var(--primary));margin-bottom:10px;}
.signal-temp{font-family:'Space Mono',monospace;font-size:72px;font-weight:700;
  color:var(--text);line-height:1;margin-bottom:6px;}
.signal-loc{font-size:18px;font-weight:700;color:var(--text);margin-bottom:4px;}
.signal-desc{font-size:14px;color:var(--text2);margin-bottom:16px;}
.alert-chip{
  display:inline-flex;align-items:center;gap:6px;
  font-size:11px;font-weight:700;padding:5px 12px;border-radius:999px;
  background:rgba(239,68,68,0.15);border:1px solid rgba(239,68,68,0.4);color:var(--red);
  margin:3px 3px 0 0;
}
.alert-chip.moderate{background:rgba(245,158,11,0.15);border-color:rgba(245,158,11,0.4);color:var(--amber);}
.alert-chip.minor{background:rgba(74,158,255,0.12);border-color:rgba(74,158,255,0.3);color:var(--primary);}

/* ─ GRID ─ */
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;}
.grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:16px;}
.grid-4{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:16px;}
@media(max-width:700px){.grid-2,.grid-4{grid-template-columns:1fr 1fr;}.grid-3{grid-template-columns:1fr;}}
@media(max-width:480px){.grid-2,.grid-4{grid-template-columns:1fr;}}

/* ─ CARDS ─ */
.card{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:16px;}
.card-title{font-size:9px;font-weight:700;letter-spacing:1.8px;text-transform:uppercase;
  color:var(--text2);margin-bottom:10px;}
.card-val{font-family:'Space Mono',monospace;font-size:28px;font-weight:700;color:var(--text);}
.card-sub{font-size:12px;color:var(--text2);margin-top:3px;}

/* ─ FORECAST ─ */
.forecast-scroll{display:flex;gap:10px;overflow-x:auto;padding-bottom:6px;margin-bottom:16px;}
.forecast-scroll::-webkit-scrollbar{height:4px;}
.forecast-scroll::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.1);border-radius:2px;}
.fc-item{min-width:90px;background:var(--surface);border:1px solid var(--border);
  border-radius:12px;padding:12px 10px;text-align:center;flex-shrink:0;}
.fc-day{font-size:10px;font-weight:700;letter-spacing:1px;color:var(--text2);margin-bottom:6px;}
.fc-icon{font-size:24px;margin-bottom:6px;}
.fc-temp{font-family:'Space Mono',monospace;font-size:16px;font-weight:700;color:var(--text);}
.fc-desc{font-size:10px;color:var(--text2);margin-top:3px;line-height:1.3;}
.fc-lo{font-family:'Space Mono',monospace;font-size:12px;color:var(--text2);margin-top:1px;}

/* ─ PRO LOCK ─ */
.pro-lock{
  border-radius:16px;padding:24px;text-align:center;
  background:rgba(74,158,255,0.06);border:1px dashed rgba(74,158,255,0.3);
  margin-bottom:16px;
}
.pro-lock-icon{font-size:32px;margin-bottom:10px;}
.pro-lock-title{font-size:16px;font-weight:800;color:var(--text);margin-bottom:6px;}
.pro-lock-sub{font-size:13px;color:var(--text2);margin-bottom:16px;line-height:1.5;}

/* ─ RADAR ─ */
.radar-frame{width:100%;aspect-ratio:16/9;border-radius:12px;border:1px solid var(--border);
  background:var(--bg2);overflow:hidden;}
.radar-frame img{width:100%;height:100%;object-fit:cover;}

/* ─ LOADING ─ */
.loading{display:flex;flex-direction:column;align-items:center;justify-content:center;
  min-height:200px;gap:12px;color:var(--text2);}
.spin{width:36px;height:36px;border:3px solid rgba(74,158,255,0.2);
  border-top-color:var(--primary);border-radius:50%;animation:spin 0.8s linear infinite;}
@keyframes spin{to{transform:rotate(360deg)}}

/* ─ SECTION TITLE ─ */
.sec-title{font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;
  color:var(--text2);margin-bottom:10px;display:flex;align-items:center;gap:8px;}
.sec-title::after{content:'';flex:1;height:1px;background:var(--border);}

/* ─ AD SLOT ─ */
.ad-slot{
  border-radius:12px;padding:14px 16px;
  background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);
  text-align:center;margin-bottom:16px;font-size:11px;color:var(--text3);
}
</style>
</head>
<body>
<div class="app">
<nav>
  <a href="/" class="nav-logo">RESILIENCE <span>WEATHER</span></a>
  <div class="nav-right">
    <% if (isPro) { %>
      <span class="plan-badge plan-pro">⚡ PRO</span>
      <% if (userName) { %><span style="font-size:12px;color:#94A3B8;">Hi, <%- userName %></span><% } %>
      <a href="/billing/portal" class="btn btn-outline btn-sm">Manage Plan</a>
      <form method="POST" action="/auth/logout" style="margin:0"><button class="btn btn-outline btn-sm" type="submit">Sign Out</button></form>
    <% } else { %>
      <span class="plan-badge plan-free">FREE</span>
      <a href="/login" class="btn btn-outline btn-sm">Sign In</a>
      <a href="/upgrade" class="btn btn-primary btn-sm">Upgrade to Pro</a>
    <% } %>
  </div>
</nav>

<main>
  <!-- Location search -->
  <div class="loc-bar">
    <div class="live-dot" id="loc-dot"></div>
    <input class="loc-input" id="loc-input" type="text" placeholder="Enter city, zip, or use GPS…" />
    <button class="btn btn-primary" onclick="useGPS()">📍 GPS</button>
    <button class="btn btn-outline" onclick="searchLocation()">Search</button>
  </div>

  <!-- Signal card -->
  <div class="signal-card" id="signal-card">
    <div id="weather-content">
      <div class="loading">
        <div class="spin"></div>
        <span>Detecting your location…</span>
      </div>
    </div>
  </div>

  <!-- Forecast -->
  <div id="forecast-section" style="display:none">
    <div class="sec-title">7-Day Forecast</div>
    <div class="forecast-scroll" id="forecast-scroll"></div>
  </div>

  <% if (!isPro) { %>
  <!-- Free tier ad -->
  <div class="ad-slot" id="ad-slot">
    📢 Advertisement · <a href="/upgrade" style="color:var(--primary);font-weight:700">Go Pro to remove ads</a>
  </div>
  <% } %>

  <!-- Stats row (free) -->
  <div id="stats-row" style="display:none">
    <div class="grid-4" id="stats-grid"></div>
  </div>

  <% if (isPro) { %>
  <!-- PRO: Radar -->
  <div id="radar-section">
    <div class="sec-title">Live Radar</div>
    <div class="radar-frame" id="radar-frame">
      <div class="loading"><div class="spin"></div><span>Loading radar…</span></div>
    </div>
  </div>

  <!-- PRO: Advanced Intelligence -->
  <div style="margin-top:20px">
    <div class="sec-title">Advanced Intelligence</div>
    <div class="grid-3">
      <div class="card">
        <div class="card-title">🌊 Flood Risk Index</div>
        <div class="card-val" id="flood-idx">—</div>
        <div class="card-sub">Calculated from NOAA gauge data</div>
      </div>
      <div class="card">
        <div class="card-title">🌡️ WBGT Heat Stress</div>
        <div class="card-val" id="wbgt-val">—</div>
        <div class="card-sub">OSHA 2026 advisory threshold</div>
      </div>
      <div class="card">
        <div class="card-title">💨 Wind Chill / Heat Index</div>
        <div class="card-val" id="feels-like">—</div>
        <div class="card-sub">Adjusted apparent temperature</div>
      </div>
    </div>
  </div>

  <!-- PRO: Citizen Science -->
  <div style="margin-top:20px">
    <div class="sec-title">Citizen Science</div>
    <div class="grid-2">
      <div class="card">
        <div class="card-title">🌧️ Log a Weather Observation</div>
        <div style="display:flex;flex-direction:column;gap:8px;margin-top:8px;">
          <select id="obs-type" style="background:rgba(255,255,255,0.07);border:1px solid var(--border);border-radius:8px;padding:8px;color:var(--text);font-family:'DM Sans',sans-serif;font-size:13px;">
            <option>Rain / Drizzle</option><option>Snow</option><option>Hail</option>
            <option>Flooding</option><option>High Winds</option><option>Clear / Calm</option>
          </select>
          <textarea id="obs-notes" placeholder="Notes (optional)…" rows="2" style="background:rgba(255,255,255,0.07);border:1px solid var(--border);border-radius:8px;padding:8px;color:var(--text);font-family:'DM Sans',sans-serif;font-size:13px;resize:none;"></textarea>
          <button class="btn btn-primary btn-sm" onclick="submitObs()">Submit to NOAA CoCoRaHS</button>
        </div>
      </div>
      <div class="card">
        <div class="card-title">📊 Your Observation History</div>
        <div id="obs-history" style="font-size:12px;color:var(--text2);margin-top:6px;">No observations submitted yet.</div>
      </div>
    </div>
  </div>

  <% } else { %>
  <!-- FREE: Pro upsell modules -->
  <div class="pro-lock">
    <div class="pro-lock-icon">🔒</div>
    <div class="pro-lock-title">Unlock Advanced Intelligence</div>
    <div class="pro-lock-sub">Live radar, flood risk index, WBGT heat stress monitoring, AI voice alerts, citizen science export, offline mesh networking, and Apple Watch sync.</div>
    <a href="/upgrade" class="btn btn-primary">Upgrade to Pro — $4.99/mo</a>
  </div>
  <% } %>

</main>
</div>

<script>
const isPro = <%- JSON.stringify(isPro) %>;
let currentData = null;

// ─── GPS auto-detect on load ────────────────────────────────────────────────
window.addEventListener('DOMContentLoaded', () => {
  if (navigator.geolocation) {
    navigator.geolocation.getCurrentPosition(
      pos => fetchWeather(pos.coords.latitude, pos.coords.longitude),
      _err => fetchWeather(35.0844, -106.6504) // fallback: Albuquerque
    );
  } else {
    fetchWeather(35.0844, -106.6504);
  }
});

function useGPS() {
  document.getElementById('loc-dot').style.background = 'var(--amber)';
  navigator.geolocation?.getCurrentPosition(
    pos => fetchWeather(pos.coords.latitude, pos.coords.longitude),
    () => alert('GPS unavailable — enter a location manually.')
  );
}

function searchLocation() {
  const val = document.getElementById('loc-input').value.trim();
  if (!val) return;
  // Geocode via nominatim (free, no key needed for low traffic)
  fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(val)}&limit=1`)
    .then(r => r.json())
    .then(data => {
      if (!data.length) return alert('Location not found. Try a different query.');
      fetchWeather(parseFloat(data[0].lat), parseFloat(data[0].lon));
    })
    .catch(() => alert('Geocoding failed.'));
}

async function fetchWeather(lat, lon) {
  document.getElementById('weather-content').innerHTML = '<div class="loading"><div class="spin"></div><span>Fetching NOAA data…</span></div>';
  document.getElementById('forecast-section').style.display = 'none';
  document.getElementById('stats-row').style.display = 'none';

  try {
    const res = await fetch(`/weather/point?lat=${lat}&lon=${lon}`);
    const data = await res.json();
    currentData = data;
    renderWeather(data);
    if (isPro) loadRadar(lat, lon);
  } catch(e) {
    document.getElementById('weather-content').innerHTML = `<p style="color:var(--red)">Failed to load weather: ${e.message}</p>`;
  }
}

const signalTheme = {
  safe:    { bg:'#001A4D', border:'rgba(74,158,255,0.3)',  glow:'rgba(74,158,255,0.1)',  color:'#4A9EFF',   label:'ALL CLEAR' },
  caution: { bg:'#002060', border:'rgba(245,158,11,0.4)',  glow:'rgba(245,158,11,0.1)',  color:'#F59E0B',   label:'ADVISORY' },
  warning: { bg:'#3B0000', border:'rgba(239,68,68,0.5)',   glow:'rgba(239,68,68,0.15)', color:'#EF4444',   label:'WARNING' },
  extreme: { bg:'#2D0040', border:'rgba(162,28,175,0.5)', glow:'rgba(162,28,175,0.15)',color:'#A855F7',  label:'EXTREME' },
};

function renderWeather(data) {
  const sig = signalTheme[data.signal] || signalTheme.safe;
  const card = document.getElementById('signal-card');
  card.style.background = sig.bg;
  card.style.borderColor = sig.border;
  card.style.setProperty('--sig-glow', sig.glow);

  const period = data.periods?.[0] || {};
  const temp   = period.temperature ? `${period.temperature}°${period.temperatureUnit || 'F'}` : '—';
  const desc   = period.shortForecast || 'Weather data loaded';
  const icon   = getWeatherIcon(desc);

  const alertChips = data.alerts.map(a => {
    const sev = (a.severity || '').toLowerCase();
    const cls = sev === 'extreme' || sev === 'severe' ? '' : sev === 'moderate' ? 'moderate' : 'minor';
    return `<span class="alert-chip ${cls}">⚠️ ${a.event}</span>`;
  }).join('');

  document.getElementById('weather-content').innerHTML = `
    <div style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:12px;">
      <div>
        <div class="signal-label" style="color:${sig.color}">${sig.label}</div>
        <div style="font-size:72px;line-height:1;">${icon}</div>
        <div style="font-family:'Space Mono',monospace;font-size:52px;font-weight:700;line-height:1.1;margin-bottom:6px;">${temp}</div>
        <div style="font-size:20px;font-weight:800;margin-bottom:4px;">${data.city}${data.state ? ', '+data.state : ''}</div>
        <div style="font-size:14px;color:var(--text2);margin-bottom:14px;">${desc}</div>
        ${alertChips ? '<div style="margin-bottom:4px;">'+alertChips+'</div>' : ''}
      </div>
      <div style="text-align:right;opacity:0.5;font-size:11px;color:var(--text2);">
        ${lat?.toFixed(3) || ''}° N, ${lon?.toFixed(3) || ''}° W<br>
        NOAA · ${new Date().toLocaleTimeString()}
      </div>
    </div>
  `;

  // Update PRO values
  if (isPro) {
    const humidity = period.relativeHumidity?.value ?? 50;
    const tempF = period.temperature ?? 70;
    const wbgt = calcWBGT(tempF, humidity);
    const feelsLike = period.windSpeed ? calcFeelsLike(tempF, period.windSpeed, humidity) : `${tempF}°F`;
    document.getElementById('wbgt-val').textContent = `${wbgt}°F`;
    document.getElementById('feels-like').textContent = feelsLike;
    document.getElementById('flood-idx').textContent = data.signal === 'extreme' ? 'HIGH' : data.signal === 'warning' ? 'MOD' : 'LOW';
  }

  // Forecast
  if (data.periods?.length) {
    renderForecast(data.periods);
    renderStats(data.periods[0]);
  }
}

function renderForecast(periods) {
  const fc = document.getElementById('forecast-scroll');

  // Pair day + night periods to show high/low
  const days = [];
  for (let i = 0; i < periods.length; i++) {
    const p = periods[i];
    if (p.isDaytime) {
      const night = periods[i + 1] && !periods[i + 1].isDaytime ? periods[i + 1] : null;
      days.push({ day: p, night });
    } else if (days.length === 0) {
      // Edge case: first period is night (after midnight)
      days.push({ day: p, night: null });
    }
  }

  fc.innerHTML = days.slice(0, 7).map(({ day, night }) => {
    const name = day.name?.replace('This', 'Today').split(' ').slice(0,1).join('') || '—';
    const hi = day.temperature ?? '—';
    const lo = night?.temperature ?? null;
    const unit = day.temperatureUnit || 'F';
    const desc = day.shortForecast || '';
    return `
    <div class="fc-item">
      <div class="fc-day">${name}</div>
      <div class="fc-icon">${getWeatherIcon(desc)}</div>
      <div class="fc-temp">${hi}°${unit}</div>
      ${lo !== null ? `<div class="fc-lo">${lo}°${unit}</div>` : ''}
      <div class="fc-desc">${desc.split(' ').slice(0,3).join(' ')}</div>
    </div>`;
  }).join('');

  document.getElementById('forecast-section').style.display = 'block';
}

function renderStats(period) {
  const stats = [
    { label:'Wind', val: period.windSpeed || '—', sub: period.windDirection || '' },
    { label:'Humidity', val: period.relativeHumidity?.value ? period.relativeHumidity.value+'%' : '—', sub:'relative humidity' },
    { label:'Dewpoint', val: period.dewpoint?.value ? Math.round(period.dewpoint.value * 9/5 + 32)+'°F' : '—', sub:'comfort index' },
    { label:'Precip %', val: period.probabilityOfPrecipitation?.value != null ? period.probabilityOfPrecipitation.value+'%' : '—', sub:'probability' },
  ];
  const grid = document.getElementById('stats-grid');
  grid.innerHTML = stats.map(s => `
    <div class="card">
      <div class="card-title">${s.label}</div>
      <div class="card-val" style="font-size:22px;">${s.val}</div>
      <div class="card-sub">${s.sub}</div>
    </div>`).join('');
  document.getElementById('stats-row').style.display = 'block';
}

async function loadRadar(lat, lon) {
  try {
    const r = await fetch(`/weather/radar?lat=${lat}&lon=${lon}`);
    const d = await r.json();
    document.getElementById('radar-frame').innerHTML = `
      <div style="position:relative;width:100%;height:100%;">
        <img src="${d.img}" alt="NOAA Radar ${d.station}" style="width:100%;height:100%;object-fit:cover;" 
             onerror="this.parentNode.innerHTML='<div style=\'padding:20px;color:var(--text2);text-align:center;\'>Radar image loading… <a href=\'${d.url}\' target=\'_blank\' style=\'color:var(--primary);\'>Open on weather.gov</a></div>'">
        <a href="${d.url}" target="_blank" style="position:absolute;bottom:10px;right:10px;background:rgba(0,0,0,0.6);color:var(--primary);font-size:10px;padding:4px 8px;border-radius:6px;text-decoration:none;font-weight:700;">STATION: ${d.station} →</a>
      </div>`;
  } catch(e) {
    document.getElementById('radar-frame').innerHTML = '<p style="padding:20px;color:var(--text2);">Radar unavailable.</p>';
  }
}

function submitObs() {
  const type = document.getElementById('obs-type').value;
  const notes = document.getElementById('obs-notes').value;
  const hist = document.getElementById('obs-history');
  const ts = new Date().toLocaleTimeString();
  hist.innerHTML = `<div style="padding:8px;background:rgba(16,185,129,0.1);border-radius:8px;border:1px solid rgba(16,185,129,0.2);margin-bottom:6px;">
    <strong style="color:var(--green)">✓ ${type}</strong> <span style="color:var(--text2)">${ts}</span>
    ${notes ? `<br><span style="color:var(--text2);font-size:11px;">${notes}</span>` : ''}
  </div>` + hist.innerHTML;
  document.getElementById('obs-notes').value = '';
}

// Helpers
function getWeatherIcon(desc='') {
  const d = desc.toLowerCase();
  if (d.includes('tornado')) return '🌪️';
  if (d.includes('hurricane')) return '🌀';
  if (d.includes('snow') || d.includes('blizzard')) return '❄️';
  if (d.includes('thunder') || d.includes('storm')) return '⛈️';
  if (d.includes('rain') || d.includes('shower')) return '🌧️';
  if (d.includes('drizzle')) return '🌦️';
  if (d.includes('fog') || d.includes('mist')) return '🌫️';
  if (d.includes('partly')) return '⛅';
  if (d.includes('cloud') || d.includes('overcast')) return '☁️';
  if (d.includes('wind')) return '💨';
  if (d.includes('sunny') || d.includes('clear')) return '☀️';
  return '🌤️';
}

function calcWBGT(tempF, humidity) {
  // Simplified Liljegren approximation
  const tw = tempF * Math.atan(0.151977 * Math.sqrt(humidity + 8.313659))
    + Math.atan(tempF + humidity) - Math.atan(humidity - 1.676331) + 0.00391838 * humidity ** 1.5
    * Math.atan(0.023101 * humidity) - 4.686035;
  return Math.round(0.7 * tw + 0.3 * tempF);
}

function calcFeelsLike(tempF, windSpeedStr, humidity) {
  const ws = parseFloat(windSpeedStr) || 0;
  if (tempF < 50 && ws > 3) {
    const wc = 35.74 + 0.6215*tempF - 35.75*ws**0.16 + 0.4275*tempF*ws**0.16;
    return `${Math.round(wc)}°F`;
  }
  if (tempF > 80) {
    const hi = -42.379 + 2.04901523*tempF + 10.14333127*humidity - 0.22475541*tempF*humidity
      - 0.00683783*tempF**2 - 0.05481717*humidity**2 + 0.00122874*tempF**2*humidity
      + 0.00085282*tempF*humidity**2 - 0.00000199*tempF**2*humidity**2;
    return `${Math.round(hi)}°F`;
  }
  return `${tempF}°F`;
}

let lat, lon;
function fetchWeather(la, lo) {
  lat=la; lon=lo;
  document.getElementById('weather-content').innerHTML = '<div class="loading"><div class="spin"></div><span>Fetching NOAA data…</span></div>';
  document.getElementById('forecast-section').style.display='none';
  document.getElementById('stats-row').style.display='none';
  fetch(`/weather/point?lat=${la}&lon=${lo}`)
    .then(r=>r.json()).then(data=>{currentData=data;renderWeather(data);if(isPro)loadRadar(la,lo);})
    .catch(e=>{ document.getElementById('weather-content').innerHTML=`<p style="color:var(--red);padding:8px;">Failed: ${e.message}</p>`; });
}
</script>
